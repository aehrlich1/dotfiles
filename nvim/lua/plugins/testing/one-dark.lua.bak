return {
  "navarasu/onedark.nvim",
  priority = 1000, -- make sure to load this before all the other start plugins
  config = function()
    require("onedark").setup({
      style = "dark",
      transparent = true,
      code_style = {
        comments = "none",
        variable = "none",
      },
    })
    require("onedark").load()
  end,
}
